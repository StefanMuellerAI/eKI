# eKI API Environment Configuration
# Copy this file to .env.local and fill in with actual values
# NEVER commit .env.local to version control!

# Environment
ENV=development
DEBUG=true

# Database
POSTGRES_DB=eki_db
POSTGRES_USER=eki_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
# Temporal auto-setup expects POSTGRES_PWD
POSTGRES_PWD=CHANGE_ME_STRONG_PASSWORD_HERE

# Database Connection
DATABASE_URL=postgresql+asyncpg://eki_user:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/eki_db
# Optional for production secrets (preferred):
# DATABASE_URL_FILE=/run/secrets/database_url

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=10

# Temporal
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=security-check

# API Security
API_SECRET_KEY=CHANGE_ME_256_BIT_SECRET_KEY_HERE
# Optional for production secrets (preferred):
# API_SECRET_KEY_FILE=/run/secrets/api_secret_key
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=

# Metrics
METRICS_ENABLED=true

# LLM Provider (ollama, mistral-cloud, local-mistral)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
# Examples: mistral, gemma4:31b, gemma4:4b, qwen3.6:35b
OLLAMA_MODEL=mistral
# Optional Ollama tuning (defaults shown)
OLLAMA_TIMEOUT=300
# Disable thinking mode for thinking-capable models (gemma4, qwen3.x)
# so structured output stays clean and fast. Ignored by mistral.
OLLAMA_THINK=false
# Context window: must cover system + taxonomy + schema + scene text.
# Lower (e.g. 16384) saves VRAM on small dev models like gemma4:4b.
OLLAMA_NUM_CTX=32768
# Embedding model for the M06 Knowledge Base. MUST produce 1024-dim vectors.
# Pull on first start:  ollama pull mxbai-embed-large
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
# Pre-truncate embed() input to fit the embedder context window.
# mxbai-embed-large hard 512-token limit ~= 1100 chars of German/Markdown
# (verified); 1000 is the safe ceiling. Raise to ~30000 for bge-m3.
OLLAMA_EMBEDDING_MAX_CHARS=1000

# Mistral Cloud (if using mistral-cloud provider)
# MISTRAL_API_KEY=your-mistral-api-key-here
# MISTRAL_API_KEY_FILE=/run/secrets/mistral_api_key

# Knowledge Base (M06)
# Master switch for KB retrieval in the risk analysis pipeline.
# Default OFF -> risk flow stays byte-identical to M05.
KB_RETRIEVAL_ENABLED=false
# Tenant UUID used for all KB documents (single-tenant default).
KB_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
# Top-k chunks injected per scene when retrieval is ON.
KB_TOP_K=3
# Max chars per chunk in the prompt to bound context length.
KB_MAX_CHUNK_CHARS_IN_PROMPT=600

# eProjekt Integration (push delivery of risk assessments)
EPRO_BASE_URL=https://staging.epro.filmakademie.de/api
# Auth is IP-based (no token needed). Set only if ePro adds token auth later:
# EPRO_AUTH_TOKEN=
# EPRO_AUTH_TOKEN_FILE=/run/secrets/epro_auth_token
EPRO_TIMEOUT=30

# CORS Origins (comma-separated)
CORS_ORIGINS=https://epro.filmakademie.de,https://staging.epro.filmakademie.de

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# =====================================================================
# M07 -- Großdokument-Optimierung (Pflichtenheft §5/§7.6)
#
# Defaults so wählen, dass das Verhalten ohne Konfig-Wechsel bytewise
# identisch zum M06-Stand bleibt. Parallel-Pfad greift NUR, wenn
# LLM_PARALLEL_ENABLED=true UND mindestens eine *_CONCURRENCY > 1 ist.
#
# WICHTIG: Ollama läuft i.d.R. auf einer geteilten GPU-Instanz, andere
# Anwendungen können denselben Endpoint nutzen. Erhöhe
# OLLAMA_MAX_CONCURRENT_REQUESTS nur, wenn Du sicher weißt, dass die
# GPU genug VRAM für N gleichzeitige Inferenzen hat. Im Zweifel auf 1
# lassen.
# =====================================================================

# Master-Flag: Default OFF = identisches Verhalten zu M06.
LLM_PARALLEL_ENABLED=false

# Prozessweiter Hard-Cap für gleichzeitige Ollama-Requests.
# Wirkt über alle Workflows und Activities hinweg.
# Empfohlene Stufen:
#   1  Default, identisch zu M06 (serialisiert)
#   2  Konservativ, ~1.6-1.8x Speedup bei dediziertem System
#   3  Sportlich, nur bei reichlich VRAM
#   >=4  Nicht empfohlen, Risiko von VRAM-Engpässen
OLLAMA_MAX_CONCURRENT_REQUESTS=1

# Optionaler Mindestabstand zwischen zwei Ollama-Calls (Millisekunden).
# 0 = aus. Für sehr knapp dimensionierte Shared-GPU-Systeme sinnvoll.
OLLAMA_MIN_INTERVAL_MS=0

# Per-Workflow-Cap: maximal parallel ausgeführte LLM-Activities pro
# Workflow. Defaults = 1 (sequenziell). Werte > 1 nur in Kombination
# mit LLM_PARALLEL_ENABLED=true wirksam.
PDF_STRUCTURE_CONCURRENCY=1
RISK_ANALYSIS_CONCURRENCY=1

# start_to_close_timeout für LLM-Activities (Sekunden).
# Vor M07 hardcoded 300s; 600s federt Backoff bei voller Ollama-Queue ab.
LLM_ACTIVITY_TIMEOUT_SECONDS=600

# PDF-Parser-Limits (vor M07 Modul-Konstanten):
MAX_PDF_PAGES=500
MAX_PDF_SIZE_BYTES=10485760
MAX_UPLOAD_SIZE_BYTES=10485760

# Temporal-Worker-Caps (vor M07 hardcoded):
WORKER_MAX_CONCURRENT_WORKFLOW_TASKS=10
WORKER_MAX_CONCURRENT_ACTIVITIES=20

# Generate secure passwords with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
